DATABASE_URL=postgres://user:password@db:5432/bud2?sslmode=disable
PORT=8080
ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=your-secret-key-at-least-32-chars
POLICY_MODEL=/policies/model.conf
POLICY_FILE=/policies/policy.csv

# Logging
# Valid values: debug, info, warn, error
LOG_LEVEL=info

# Observability (OpenTelemetry)
# Leave empty to use no-op exporter (no traces sent)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bud2-backend
OTEL_ENVIRONMENT=development
